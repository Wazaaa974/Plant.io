<% content_for :title, "Choose a new password | plante.io" %>

<section class="mx-auto max-w-2xl rounded-[2rem] border border-white/10 bg-stone-900/80 p-8">
  <p class="text-sm uppercase tracking-[0.2em] text-emerald-200/80">New password</p>
  <h1 class="mt-3 font-serif text-4xl text-white">Choose a fresh password.</h1>

  <%= form_with url: password_path(params[:token]), method: :put, class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :password, "Password", class: "mb-2 block text-sm text-stone-300" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none transition placeholder:text-stone-500 focus:border-emerald-300/40", placeholder: "New password" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm text-stone-300" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none transition placeholder:text-stone-500 focus:border-emerald-300/40", placeholder: "Repeat password" %>
    </div>

    <%= form.submit "Save new password", class: "rounded-full bg-emerald-300 px-5 py-3 font-medium text-stone-950 transition hover:bg-emerald-200" %>
  <% end %>
</section>
