<% content_for :title, "Choose a new password | plante.io" %>

<section class="mx-auto max-w-2xl pio-glass rounded-[2.1rem] p-7 sm:p-8">
  <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">New password</p>
  <h1 class="mt-2 font-serif text-[2.4rem] tracking-[-0.07em] text-[var(--pio-cream)]">Choisir un nouveau mot de passe.</h1>

  <%= form_with url: password_path(params[:token]), method: :put, class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :password, "Password", class: "mb-2 block text-sm text-white/62" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "New password" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm text-white/62" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "Repeat password" %>
    </div>

    <%= form.submit "Enregistrer", class: "inline-flex rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
  <% end %>
</section>
