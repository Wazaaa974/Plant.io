<% content_for :title, "Reset password | plante.io" %>

<section class="mx-auto max-w-2xl pio-glass rounded-[2.1rem] p-7 sm:p-8">
  <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">Password reset</p>
  <h1 class="mt-2 font-serif text-[2.4rem] tracking-[-0.07em] text-[var(--pio-cream)]">Retrouver ta jungle.</h1>
  <p class="mt-4 text-sm leading-7 text-white/56">Entre l'email du compte et on t'enverra un lien si l'adresse existe.</p>

  <%= form_with url: passwords_path, class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-white/62" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "you@example.com" %>
    </div>

    <%= form.submit "Envoyer le lien", class: "inline-flex rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
  <% end %>
</section>
