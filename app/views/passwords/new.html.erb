<% content_for :title, "Reset password | plante.io" %>

<section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
  <div class="relative overflow-hidden rounded-[2.3rem] border border-white/8 bg-white/5 p-8 lg:p-10">
    <div class="absolute right-[-10%] top-[-10%] h-56 w-56 rounded-full pio-aura-mint blur-2xl"></div>
    <div class="absolute bottom-[-16%] left-[-10%] h-48 w-48 rounded-full pio-aura-violet blur-2xl"></div>

    <div class="relative">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--pio-leaf)]/75">Password reset</p>
      <h1 class="mt-3 max-w-xl font-serif text-[2.8rem] leading-[0.98] tracking-[-0.08em] text-[var(--pio-cream)]">
        Retrouver ta <span class="text-[var(--pio-leaf)]">jungle vivante</span>.
      </h1>
      <p class="mt-4 max-w-md text-sm leading-7 text-white/58">
        Entre ton email et on t'aide a revenir dans ta collection de plantes, leurs photos et leur progression.
      </p>

      <div class="mt-6 rounded-[1.3rem] border border-white/8 bg-[rgba(6,18,14,0.34)] p-4">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/42">Ce que tu retrouves apres connexion</p>
        <div class="mt-3 grid gap-2 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/6 bg-white/4 px-3 py-3">
            <p class="text-[0.72rem] text-white/40">Plantes</p>
            <p class="mt-1 text-sm font-semibold text-[var(--pio-cream)]">Ta collection</p>
          </div>
          <div class="rounded-2xl border border-white/6 bg-white/4 px-3 py-3">
            <p class="text-[0.72rem] text-white/40">Photos</p>
            <p class="mt-1 text-sm font-semibold text-[var(--pio-cream)]">Ton histoire visuelle</p>
          </div>
          <div class="rounded-2xl border border-white/6 bg-white/4 px-3 py-3">
            <p class="text-[0.72rem] text-white/40">Progression</p>
            <p class="mt-1 text-sm font-semibold text-[var(--pio-cream)]">XP et stades</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pio-glass rounded-[2.1rem] p-7 sm:p-8">
    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">Password reset</p>
    <h2 class="mt-2 font-display text-[1.85rem] font-semibold tracking-[-0.05em] text-[var(--pio-cream)]">Envoyer un lien de retour.</h2>
    <p class="mt-3 text-sm leading-7 text-white/56">Entre l'email du compte et on t'enverra un lien si l'adresse existe.</p>

    <%= form_with url: passwords_path, class: "mt-8 space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-white/62" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "you@example.com" %>
      </div>

      <%= form.submit "Envoyer le lien", class: "inline-flex rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
    <% end %>

    <p class="mt-5 text-sm text-white/42">
      Tu te souviens de ton mot de passe ?
      <%= link_to "Retour a la connexion", new_session_path, class: "font-semibold text-[var(--pio-leaf)] transition hover:text-[var(--pio-mint)]" %>
    </p>
  </div>
</section>
