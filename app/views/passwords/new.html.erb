<% content_for :title, "Reset password | plante.io" %>

<section class="mx-auto max-w-2xl rounded-[2rem] border border-white/10 bg-stone-900/80 p-8">
  <p class="text-sm uppercase tracking-[0.2em] text-emerald-200/80">Password reset</p>
  <h1 class="mt-3 font-serif text-4xl text-white">Get back into your collection.</h1>
  <p class="mt-4 text-stone-300">Enter the email used for your account and we will send reset instructions if it exists.</p>

  <%= form_with url: passwords_path, class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-stone-300" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none transition placeholder:text-stone-500 focus:border-emerald-300/40", placeholder: "you@example.com" %>
    </div>

    <%= form.submit "Email reset instructions", class: "rounded-full bg-emerald-300 px-5 py-3 font-medium text-stone-950 transition hover:bg-emerald-200" %>
  <% end %>
</section>
