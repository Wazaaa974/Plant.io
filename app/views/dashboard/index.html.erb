<% content_for :title, "Dashboard | plante.io" %>

<section class="pb-24">
  <div class="mb-2 flex items-start justify-between gap-4">
    <div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--pio-leaf)]/75">Ma Jungle · <%= @plants.size %> plantes</p>
      <h1 class="mt-2 max-w-[16rem] font-serif text-[2rem] font-normal leading-[1.05] tracking-[-0.06em] text-[var(--pio-cream)]">
        Bonjour <%= pio_greeting_name(current_user) %>, <span class="text-[var(--pio-leaf)]">ta jungle est calme.</span>
      </h1>
    </div>
    <div class="relative flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/6 text-[var(--pio-cream)]/90 backdrop-blur">
      <%= pio_icon(:bell, size: 18) %>
      <span class="absolute right-2 top-2 h-2 w-2 rounded-full bg-[var(--pio-mint)] shadow-[0_0_10px_rgba(91,255,152,0.8)]"></span>
    </div>
  </div>

  <p class="mb-6 mt-4 text-sm leading-6 text-white/62">
    <% if @latest_observation.present? %>
      <%= @featured_plant&.display_name || "Une de tes plantes" %> a un nouveau moment a raconter. <%= @latest_observation.title %>.
    <% else %>
      Une photo, une note ou une nouvelle feuille suffisent pour faire vivre ta collection.
    <% end %>
  </p>

  <section class="pio-glass rounded-[1.6rem] p-4">
    <div class="mb-3 flex items-start justify-between gap-4">
      <div>
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-white/42">Aujourd'hui</p>
        <p class="mt-1 font-display text-[1.7rem] font-semibold tracking-[-0.05em] text-[var(--pio-cream)]">
          +<%= @today_xp %> <span class="text-[var(--pio-mint)]">XP</span>
        </p>
      </div>

      <div class="flex items-center gap-2">
        <% [
          { ratio: @today_xp.zero? ? 0.15 : 0.85, color: "var(--pio-mint)" },
          { ratio: @plants.any? ? 0.6 : 0.18, color: "var(--pio-sun)" },
          { ratio: @latest_observation.present? ? 0.45 : 0.1, color: "var(--pio-violet)" }
        ].each do |ring| %>
          <div class="grid h-11 w-11 place-items-center rounded-full border border-white/8 bg-black/10">
            <div class="grid h-8 w-8 place-items-center rounded-full border-2" style="border-color: color-mix(in srgb, <%= ring[:color] %> 100%, transparent); box-shadow: 0 0 10px color-mix(in srgb, <%= ring[:color] %> 45%, transparent);">
              <div class="h-2.5 w-2.5 rounded-full" style="background: <%= ring[:color] %>;"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="pio-progress relative h-2 overflow-hidden rounded-full bg-white/8">
      <span class="absolute inset-y-0 left-0 rounded-full bg-[linear-gradient(90deg,_var(--pio-mint),_var(--pio-leaf))]" style="width: <%= [[(@today_xp.to_f / 150) * 100, 14].max, 100].min %>%"></span>
    </div>
    <div class="mt-2 flex items-center justify-between text-[0.72rem] text-white/45">
      <span>Niveau attention</span>
      <span><%= @today_xp %> / 150</span>
    </div>
  </section>

  <div class="mt-6">
    <p class="mb-3 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">A surveiller</p>
    <div class="grid grid-cols-2 gap-3">
      <div class="pio-glass rounded-[1.2rem] p-3.5">
        <div class="mb-3 grid h-8 w-8 place-items-center rounded-[0.8rem] bg-[#7CC4FF]/16 text-[#7CC4FF]">
          <%= pio_icon(:drop, size: 16, stroke_width: 2.1) %>
        </div>
        <p class="text-sm font-semibold text-[var(--pio-cream)]"><%= @featured_plant&.display_name || "Ta prochaine plante" %></p>
        <p class="mt-1 text-[0.72rem] text-white/45">Une photo ou un evenement suffit pour faire avancer son niveau.</p>
      </div>

      <div class="pio-glass rounded-[1.2rem] p-3.5">
        <div class="mb-3 grid h-8 w-8 place-items-center rounded-[0.8rem] bg-[var(--pio-violet)]/16 text-[var(--pio-violet)]">
          <%= pio_icon(:sparkle, size: 16, stroke_width: 2.1) %>
        </div>
        <p class="text-sm font-semibold text-[var(--pio-cream)]">Aura en progression</p>
        <p class="mt-1 text-[0.72rem] text-white/45">Le style prototype favorise les plantes qui ont une histoire a raconter.</p>
      </div>
    </div>
  </div>

  <% if @featured_plant.present? %>
    <% stage = pio_stage_meta(@featured_plant.growth_stage) %>
    <section class="mt-6 pio-glass overflow-hidden rounded-[1.8rem]">
      <div class="relative h-72">
        <% if @featured_plant.hero_photo&.image&.attached? %>
          <%= image_tag @featured_plant.hero_photo.image, class: "h-full w-full object-cover" %>
        <% else %>
          <div class="h-full w-full bg-[radial-gradient(circle_at_top,_rgba(91,255,152,0.22),_transparent_38%),linear-gradient(180deg,_rgba(11,47,36,1)_0%,_rgba(8,30,23,1)_100%)]"></div>
        <% end %>
        <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,_rgba(8,30,23,0.18)_0%,_rgba(8,30,23,0.04)_35%,_rgba(8,30,23,0.68)_100%)]"></div>
        <div class="absolute inset-x-0 bottom-0 p-4">
          <div class="flex items-end justify-between gap-3">
            <div>
              <p class="text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-[var(--pio-leaf)]/75">Plante mise en avant</p>
              <h2 class="mt-1 font-serif text-[2.2rem] tracking-[-0.08em] text-[var(--pio-cream)]"><%= @featured_plant.display_name %></h2>
              <p class="mt-1 text-sm italic text-white/50"><%= @featured_plant.species_label %><% if @featured_plant.location_name.present? %> · <%= @featured_plant.location_name %><% end %></p>
            </div>
            <div class="grid h-14 w-14 place-items-center rounded-full border bg-[#0b1f18]/70 text-sm font-display font-semibold backdrop-blur-xl" style="border-color: color-mix(in srgb, <%= stage[:color] %> 100%, transparent); color: <%= stage[:color] %>;">
              <span class="text-[0.62rem] opacity-70">Lv</span>
              <span class="-mt-1 text-base"><%= @featured_plant.level %></span>
            </div>
          </div>
        </div>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-xs font-semibold" style="border-color: color-mix(in srgb, <%= stage[:color] %> 45%, transparent); color: <%= stage[:color] %>; background: color-mix(in srgb, <%= stage[:color] %> 12%, transparent);">
              <%= pio_icon(stage[:icon], size: 14, stroke_width: 2.1) %>
              <span><%= stage[:label] %></span>
            </div>
            <p class="mt-3 text-sm leading-6 text-white/52"><%= pio_stage_supporting_copy(@featured_plant.growth_stage) %></p>
          </div>
          <div class="rounded-[1.2rem] border border-white/8 bg-black/10 px-3 py-2 text-right">
            <p class="text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-white/36">Stade</p>
            <p class="mt-1 font-display text-base font-semibold text-[var(--pio-cream)]"><%= pio_stage_step_label(@featured_plant.growth_stage) %></p>
          </div>
        </div>

        <div class="mt-4 rounded-[1.3rem] border border-white/8 bg-black/10 p-3.5">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-white/40">Progression du niveau</p>
              <p class="mt-1 font-display text-base font-semibold text-[var(--pio-cream)]"><%= pio_level_progress_label(@featured_plant) %></p>
            </div>
            <div class="text-right">
              <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-white/36">Ensuite</p>
              <p class="mt-1 text-sm font-semibold text-[var(--pio-mint)]"><%= pio_next_level_label(@featured_plant) %></p>
            </div>
          </div>
          <div class="mt-3 pio-progress relative h-2 overflow-hidden rounded-full bg-white/8">
            <span class="absolute inset-y-0 left-0 rounded-full bg-[linear-gradient(90deg,_var(--pio-mint),_var(--pio-leaf))]" style="width: <%= pio_growth_percent(@featured_plant) %>%"></span>
          </div>
          <div class="mt-2 flex items-center justify-between text-[0.72rem] text-white/45">
            <span>Total <%= @featured_plant.xp %> XP</span>
            <span>Encore <span class="font-semibold text-[var(--pio-cream)]"><%= [100 - @featured_plant.xp_progress, 0].max %> XP</span></span>
          </div>
        </div>

        <% if (next_stage = pio_next_stage_meta(@featured_plant.growth_stage)).present? %>
          <div class="mt-3 flex items-center justify-between rounded-[1.15rem] border border-white/8 bg-white/4 px-3 py-2.5 text-sm">
            <span class="text-white/48">Prochain stade</span>
            <span class="inline-flex items-center gap-2 font-semibold" style="color: <%= next_stage[:color] %>;">
              <%= pio_icon(next_stage[:icon], size: 14, stroke_width: 2.1) %>
              <%= next_stage[:label] %>
            </span>
          </div>
        <% end %>
        <div class="mt-4 flex items-center gap-2">
          <%= link_to "Ouvrir sa fiche", plant_path(@featured_plant), class: "inline-flex rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-4 py-2.5 text-sm font-semibold text-[var(--pio-forest)]" %>
          <%= link_to "Journal", plant_path(@featured_plant), class: "inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2.5 text-sm font-medium text-white/72" %>
        </div>
      </div>
    </section>
  <% end %>

  <div class="mt-6 flex items-center justify-between">
    <div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">Collection</p>
      <p class="mt-1 text-sm text-white/52">Cartes vivantes, aura et progression douce.</p>
    </div>
    <%= link_to "Voir tout", plants_path, class: "text-sm font-semibold text-[var(--pio-mint)]" %>
  </div>

  <% if @plants.any? %>
    <div class="mt-4 grid grid-cols-2 gap-3">
      <% @plants.first(4).each do |plant| %>
        <%= render "shared/plant_card", plant: plant %>
      <% end %>
    </div>
  <% else %>
    <div class="pio-glass mt-4 rounded-[1.7rem] border border-dashed p-8 text-center">
      <p class="font-serif text-[1.8rem] tracking-[-0.05em] text-[var(--pio-cream)]">La jungle attend sa premiere plante.</p>
      <p class="mx-auto mt-3 max-w-[16rem] text-sm leading-6 text-white/45">Commence avec une photo et un nom, puis on donnera a la collection sa vraie personnalite.</p>
      <div class="mx-auto mt-5 grid max-w-[18rem] gap-2 text-left text-sm text-white/55">
        <div class="rounded-[1rem] border border-white/8 bg-white/4 px-3 py-2.5">1. Ajouter une plante</div>
        <div class="rounded-[1rem] border border-white/8 bg-white/4 px-3 py-2.5">2. Lui donner une photo et un nom</div>
        <div class="rounded-[1rem] border border-white/8 bg-white/4 px-3 py-2.5">3. Revenir pour suivre sa progression</div>
      </div>
      <%= link_to "Ajouter une plante", new_plant_path, class: "mt-5 inline-flex rounded-full bg-[var(--pio-mint)] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)]" %>
    </div>
  <% end %>
</section>

<%= render "shared/bottom_nav", active: :jungle %>
