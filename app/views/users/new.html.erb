<% content_for :title, "Create account | plante.io" %>

<section class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
  <div class="relative overflow-hidden rounded-[2.3rem] border border-white/8 bg-white/5 p-8 lg:p-10">
    <div class="absolute right-[-10%] top-[-10%] h-56 w-56 rounded-full pio-aura-mint blur-2xl"></div>
    <div class="absolute bottom-[-16%] left-[-10%] h-48 w-48 rounded-full pio-aura-violet blur-2xl"></div>

    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[var(--pio-leaf)]/80">
        <span class="inline-block h-2 w-2 rounded-full bg-[var(--pio-mint)] shadow-[0_0_12px_rgba(91,255,152,0.8)]"></span>
        MVP web app
      </div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--pio-leaf)]/75">Create account</p>
      <h1 class="mt-3 max-w-xl font-serif text-[2.8rem] leading-[0.98] tracking-[-0.08em] text-[var(--pio-cream)]">
        Donne une vraie <span class="text-[var(--pio-leaf)]">maison numerique</span> a tes plantes.
      </h1>
      <p class="mt-4 max-w-md text-sm leading-7 text-white/58">
        Cree ton compte pour transformer tes plantes en compagnons vivants avec photos, progression et journal de croissance.
      </p>

      <div class="mt-6 grid gap-3 sm:grid-cols-3">
        <div class="pio-glass rounded-[1.2rem] p-4">
          <p class="text-[0.7rem] uppercase tracking-[0.18em] text-white/40">1</p>
          <p class="mt-2 text-sm font-semibold text-[var(--pio-cream)]">Ajoute une plante</p>
          <p class="mt-1 text-[0.78rem] leading-5 text-white/46">Nom, photo, premiere fiche vivante.</p>
        </div>
        <div class="pio-glass rounded-[1.2rem] p-4">
          <p class="text-[0.7rem] uppercase tracking-[0.18em] text-white/40">2</p>
          <p class="mt-2 text-sm font-semibold text-[var(--pio-cream)]">Observe sa croissance</p>
          <p class="mt-1 text-[0.78rem] leading-5 text-white/46">Niveaux, XP et souvenirs visuels.</p>
        </div>
        <div class="pio-glass rounded-[1.2rem] p-4">
          <p class="text-[0.7rem] uppercase tracking-[0.18em] text-white/40">3</p>
          <p class="mt-2 text-sm font-semibold text-[var(--pio-cream)]">Reviens chaque semaine</p>
          <p class="mt-1 text-[0.78rem] leading-5 text-white/46">Une nouvelle photo suffit pour relancer la boucle.</p>
        </div>
      </div>

      <div class="mt-6 rounded-[1.3rem] border border-white/8 bg-[rgba(6,18,14,0.34)] p-4">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/42">Ce que tu obtiens des le depart</p>
        <ul class="mt-3 space-y-2 text-sm text-white/60">
          <li class="flex items-start gap-3"><span class="mt-1 text-[var(--pio-mint)]"><%= pio_icon(:sparkle, size: 14, stroke_width: 2.2) %></span><span>Une collection claire de toutes tes plantes</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 text-[var(--pio-sun)]"><%= pio_icon(:camera, size: 14, stroke_width: 2.2) %></span><span>Une fiche par plante avec photos, stade et progression</span></li>
          <li class="flex items-start gap-3"><span class="mt-1 text-[var(--pio-leaf)]"><%= pio_icon(:sparkle, size: 14, stroke_width: 2.2) %></span><span>Un debut de journal vivant que tu peux faire grandir dans le temps</span></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="pio-glass rounded-[2.1rem] p-7 sm:p-8">
    <div class="mb-6">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">New account</p>
      <h2 class="mt-2 font-display text-[1.85rem] font-semibold tracking-[-0.05em] text-[var(--pio-cream)]">Commencer ma jungle.</h2>
      <p class="mt-2 text-sm leading-6 text-white/50">En quelques minutes, tu peux creer ton compte puis ajouter ta premiere plante.</p>
    </div>

    <%= form_with model: @user, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-white/62" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "mb-2 block text-sm text-white/62" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "Create a password" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm text-white/62" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "Repeat your password" %>
      </div>

      <%= form.submit "Creer mon compte", class: "inline-flex w-full items-center justify-center rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
    <% end %>

    <p class="mt-5 text-center text-sm text-white/42">
      Deja inscrit ?
      <%= link_to "Se connecter", new_session_path, class: "font-semibold text-[var(--pio-leaf)] transition hover:text-[var(--pio-mint)]" %>
    </p>
  </div>
</section>
