<% content_for :title, "Create account | plante.io" %>

<section class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
  <div class="relative overflow-hidden rounded-[2.3rem] border border-white/8 bg-white/5 p-8 lg:p-10">
    <div class="absolute right-[-10%] top-[-10%] h-56 w-56 rounded-full pio-aura-mint blur-2xl"></div>
    <div class="absolute bottom-[-16%] left-[-10%] h-48 w-48 rounded-full pio-aura-violet blur-2xl"></div>

    <div class="relative">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--pio-leaf)]/75">Create account</p>
      <h1 class="mt-3 max-w-xl font-serif text-[2.8rem] leading-[0.98] tracking-[-0.08em] text-[var(--pio-cream)]">
        Donne une vraie <span class="text-[var(--pio-leaf)]">maison numerique</span> a tes plantes.
      </h1>
      <p class="mt-4 max-w-md text-sm leading-7 text-white/58">
        On commence simple : une collection, des photos, de l'XP et des histoires de croissance. Le reste viendra ensuite.
      </p>
    </div>
  </div>

  <div class="pio-glass rounded-[2.1rem] p-7 sm:p-8">
    <div class="mb-6">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">New account</p>
      <h2 class="mt-2 font-display text-[1.85rem] font-semibold tracking-[-0.05em] text-[var(--pio-cream)]">Commencer ma jungle.</h2>
    </div>

    <%= form_with model: @user, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-white/62" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "mb-2 block text-sm text-white/62" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "Create a password" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm password", class: "mb-2 block text-sm text-white/62" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "Repeat your password" %>
      </div>

      <%= form.submit "Creer mon compte", class: "inline-flex w-full items-center justify-center rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
    <% end %>
  </div>
</section>
