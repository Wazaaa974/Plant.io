<% content_for :title, "Plants | plante.io" %>

<section class="pb-24">
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">Collection complete</p>
      <h1 class="mt-2 font-serif text-[2rem] tracking-[-0.06em] text-[var(--pio-cream)]">Toutes tes plantes</h1>
      <p class="mt-2 text-sm leading-6 text-white/48">La version web garde l'esprit collection du prototype mobile.</p>
    </div>

    <%= link_to new_plant_path, class: "grid h-12 w-12 place-items-center rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] text-[var(--pio-forest)] shadow-[0_8px_24px_rgba(91,255,152,0.35)]" do %>
      <%= pio_icon(:plus, size: 22, stroke_width: 2.4) %>
    <% end %>
  </div>

  <% if @plants.any? %>
    <section class="mt-6 grid grid-cols-2 gap-3">
      <% @plants.each do |plant| %>
        <%= render "shared/plant_card", plant: plant %>
      <% end %>
    </section>
  <% else %>
    <section class="mt-6 pio-glass rounded-[1.8rem] border border-dashed p-8 text-center">
      <p class="font-serif text-[1.9rem] tracking-[-0.06em] text-[var(--pio-cream)]">Ta collection est encore vide.</p>
      <p class="mx-auto mt-3 max-w-[17rem] text-sm leading-6 text-white/48">La premiere plante suffit pour lancer toute l'experience : fiche, progression, photos et histoire.</p>

      <div class="mx-auto mt-5 grid max-w-[18rem] gap-2 text-left text-sm text-white/55">
        <div class="rounded-[1rem] border border-white/8 bg-white/4 px-3 py-2.5">Choisis une plante de chez toi</div>
        <div class="rounded-[1rem] border border-white/8 bg-white/4 px-3 py-2.5">Ajoute une photo et un nom</div>
        <div class="rounded-[1rem] border border-white/8 bg-white/4 px-3 py-2.5">Retrouve-la ensuite dans ta jungle</div>
      </div>

      <%= link_to "Ajouter ma premiere plante", new_plant_path, class: "mt-6 inline-flex rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
    </section>
  <% end %>
</section>

<%= render "shared/bottom_nav", active: :collection %>
