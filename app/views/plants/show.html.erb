<% content_for :title, "#{@plant.display_name} | plante.io" %>

<% stage = pio_stage_meta(@plant.growth_stage) %>

<section class="pb-24">
  <div class="relative -mx-4 -mt-5 overflow-hidden rounded-b-[2.4rem]">
    <div class="absolute inset-0 pio-aura-mint opacity-80"></div>
    <% if @plant.hero_photo&.image&.attached? %>
      <%= image_tag @plant.hero_photo.image, class: "h-[22rem] w-full object-cover" %>
    <% else %>
      <div class="h-[22rem] w-full bg-[radial-gradient(circle_at_top,_rgba(91,255,152,0.22),_transparent_38%),linear-gradient(180deg,_rgba(11,47,36,1)_0%,_rgba(8,30,23,1)_100%)]"></div>
    <% end %>
    <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,_rgba(8,30,23,0.38)_0%,_rgba(8,30,23,0)_32%,_rgba(8,30,23,0.52)_76%,_#081e17_100%)]"></div>

    <div class="absolute inset-x-4 top-4 flex items-center justify-between">
      <%= link_to root_path, class: "grid h-10 w-10 place-items-center rounded-full border border-white/10 bg-[#0b1f18]/55 text-[var(--pio-cream)] backdrop-blur-xl" do %>
        <%= pio_icon(:chevron_left, size: 18) %>
      <% end %>

      <div class="grid h-10 w-10 place-items-center rounded-full border border-white/10 bg-[#0b1f18]/55 text-[var(--pio-cream)] backdrop-blur-xl">
        <%= pio_icon(:dots, size: 18) %>
      </div>
    </div>

    <div class="absolute bottom-6 right-5 grid h-14 w-14 place-items-center rounded-full border text-sm font-display font-semibold shadow-[0_0_18px_rgba(91,255,152,0.4)] backdrop-blur-xl" style="border-color: color-mix(in srgb, <%= stage[:color] %> 100%, transparent); color: <%= stage[:color] %>; background: rgba(11,31,24,0.7);">
      <span class="text-[0.62rem] opacity-70">Lv</span>
      <span class="-mt-1 text-base"><%= @plant.level %></span>
    </div>
  </div>

  <div class="relative mt-[-1.65rem] px-1">
    <h1 class="font-serif text-[2.8rem] font-normal leading-none tracking-[-0.08em] text-[var(--pio-cream)]"><%= @plant.display_name %></h1>
    <p class="mt-2 text-sm italic text-white/52"><%= @plant.species_name %><% if @plant.location_name.present? %> · <%= @plant.location_name %><% end %></p>

    <div class="mt-4 inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-xs font-semibold" style="border-color: color-mix(in srgb, <%= stage[:color] %> 45%, transparent); color: <%= stage[:color] %>; background: color-mix(in srgb, <%= stage[:color] %> 12%, transparent);">
      <%= pio_icon(stage[:icon], size: 14, stroke_width: 2.1) %>
      <span><%= stage[:label] %></span>
    </div>

    <section class="pio-glass mt-5 rounded-[1.5rem] p-4">
      <div class="mb-3 flex items-center justify-between gap-3">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-[var(--pio-leaf)]/75">Prochaine etape</p>
        <p class="font-display text-sm font-semibold text-[var(--pio-mint)]"><%= stage[:label] %></p>
      </div>
      <div class="pio-progress relative h-2 overflow-hidden rounded-full bg-white/8">
        <span class="absolute inset-y-0 left-0 rounded-full bg-[linear-gradient(90deg,_var(--pio-mint),_var(--pio-leaf))]" style="width: <%= pio_growth_percent(@plant) %>%"></span>
      </div>
      <div class="mt-2 flex items-center justify-between text-[0.72rem] text-white/45">
        <span><%= @plant.xp %> / <%= @plant.xp_for_next_level %> XP</span>
        <span>Encore <span class="font-semibold text-[var(--pio-cream)]"><%= @remaining_xp %> XP</span></span>
      </div>
    </section>

    <div class="mt-4 grid grid-cols-4 gap-2">
      <% [
        { label: "Photo", icon: :camera, primary: true },
        { label: "Arroser", icon: :drop },
        { label: "Feuille", icon: :leaf },
        { label: "Note", icon: :sparkle }
      ].each do |action| %>
        <div class="<%= action[:primary] ? 'bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] text-[var(--pio-forest)]' : 'pio-glass text-white/75' %> grid aspect-square place-items-center rounded-[1.2rem] p-2">
          <div class="flex flex-col items-center gap-1">
            <%= pio_icon(action[:icon], size: 19, stroke_width: 2.1) %>
            <span class="text-[0.6rem] font-semibold uppercase tracking-[0.08em]"><%= action[:label] %></span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-4 grid grid-cols-3 gap-2">
      <div class="pio-glass rounded-[1rem] p-3 text-center">
        <p class="font-display text-lg font-semibold text-[var(--pio-cream)]"><%= @days_together.present? ? distance_of_time_in_words(Date.current, @plant.acquired_at) : "-" %></p>
        <p class="mt-1 text-[0.6rem] uppercase tracking-[0.16em] text-white/38">Suivie depuis</p>
      </div>
      <div class="pio-glass rounded-[1rem] p-3 text-center">
        <p class="font-display text-lg font-semibold text-[var(--pio-sun)]"><%= @plant_photos.size %></p>
        <p class="mt-1 text-[0.6rem] uppercase tracking-[0.16em] text-white/38">Photos</p>
      </div>
      <div class="pio-glass rounded-[1rem] p-3 text-center">
        <p class="font-display text-lg font-semibold text-[var(--pio-mint)]"><%= @plant_events.count(&:new_leaf?) %></p>
        <p class="mt-1 text-[0.6rem] uppercase tracking-[0.16em] text-white/38">Feuilles</p>
      </div>
    </div>

    <% if @latest_observation.present? %>
      <section class="mt-5 flex gap-3 rounded-[1.2rem] border border-[var(--pio-violet)]/30 bg-[linear-gradient(135deg,_rgba(142,91,255,0.16),_rgba(91,255,152,0.08))] p-4">
        <div class="grid h-8 w-8 shrink-0 place-items-center rounded-[0.8rem] bg-[var(--pio-violet)]/25 text-[var(--pio-violet)]">
          <%= pio_icon(:sparkle, size: 14, stroke_width: 2.1) %>
        </div>
        <div>
          <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[var(--pio-violet)]">Observation</p>
          <p class="mt-1 font-serif text-base italic leading-6 text-[var(--pio-cream)]"><%= @latest_observation.notes.presence || @latest_observation.title %></p>
        </div>
      </section>
    <% end %>

    <section class="mt-7">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-[var(--pio-leaf)]/75">Son histoire</p>
          <h2 class="mt-1 font-serif text-[2rem] tracking-[-0.06em] text-[var(--pio-cream)]">Timeline</h2>
        </div>
        <p class="text-xs text-white/45"><%= @plant_events.size %> entrees</p>
      </div>

      <div class="relative pl-11">
        <div class="absolute left-3 top-2 bottom-3 w-[2px] rounded-full bg-[linear-gradient(180deg,_var(--pio-mint),_rgba(91,255,152,0.18)_70%,_transparent)]"></div>

        <% @plant_events.each do |event| %>
          <% event_meta = pio_event_meta(event.event_type) %>
          <% milestone = event.repotting? || event.flowering? %>
          <article class="relative mb-4">
            <div class="absolute -left-11 top-7 grid h-7 w-7 place-items-center rounded-full border-2 bg-[rgba(11,31,24,0.96)]" style="border-color: <%= event_meta[:color] %>; color: <%= event_meta[:color] %>; box-shadow: 0 0 12px color-mix(in srgb, <%= event_meta[:color] %> 50%, transparent);">
              <%= pio_icon(event_meta[:icon], size: 13, stroke_width: 2.1) %>
            </div>

            <p class="mb-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-white/36"><%= time_ago_in_words(event.occurred_at) %></p>

            <div class="pio-glass overflow-hidden rounded-[1.3rem] <%= milestone ? 'ring-1 ring-[var(--pio-sun)]/35' : '' %>">
              <% photo = @plant_photos.find { |plant_photo| plant_photo.taken_at.to_date == event.occurred_at.to_date && plant_photo.image.attached? } %>
              <% if photo.present? %>
                <div class="relative h-36">
                  <%= image_tag photo.image, class: "h-full w-full object-cover" %>
                  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,_transparent_45%,_rgba(8,30,23,0.72)_100%)]"></div>
                </div>
              <% end %>

              <div class="p-4">
                <div class="flex items-center justify-between gap-3">
                  <h3 class="font-display text-[0.96rem] font-semibold tracking-[-0.03em] text-[var(--pio-cream)]"><%= event.title %></h3>
                  <span class="text-xs font-semibold <%= milestone ? 'text-[var(--pio-sun)]' : 'text-[var(--pio-mint)]' %>">+<%= event.xp_delta %> XP</span>
                </div>
                <p class="mt-1 text-sm leading-6 text-white/58"><%= event.notes %></p>
              </div>
            </div>
          </article>
        <% end %>

        <div class="relative pt-1 text-sm italic text-[var(--pio-leaf)]/72">
          <% if @plant.acquired_at.present? %>
            Le <%= l(@plant.acquired_at, format: :long) %>, <%= @plant.display_name %> est arrivee a la maison.
          <% else %>
            L'histoire commence ici.
          <% end %>
        </div>
      </div>
    </section>
  </div>
</section>

<%= render "shared/bottom_nav", active: :journal %>
