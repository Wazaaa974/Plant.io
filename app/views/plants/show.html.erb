<% content_for :title, "#{@plant.display_name} | plante.io" %>

<section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
  <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-sm uppercase tracking-[0.2em] text-emerald-200/80"><%= @plant.growth_stage.humanize %></p>
        <h1 class="mt-2 font-serif text-4xl text-white"><%= @plant.display_name %></h1>
        <p class="mt-2 text-lg text-stone-300"><%= @plant.species_name %></p>
        <% if @plant.common_name.present? %>
          <p class="text-sm text-stone-400"><%= @plant.common_name %></p>
        <% end %>
      </div>

      <div class="rounded-[1.5rem] border border-white/10 bg-black/10 px-5 py-4 text-right">
        <p class="text-sm text-stone-400">Level</p>
        <p class="font-serif text-4xl text-white"><%= @plant.level %></p>
        <p class="text-sm text-stone-300"><%= @plant.xp %> XP</p>
      </div>
    </div>

    <div class="mt-8 overflow-hidden rounded-[1.5rem] bg-stone-900/80">
      <% if @plant.hero_photo&.image&.attached? %>
        <%= image_tag @plant.hero_photo.image, class: "h-[28rem] w-full object-cover" %>
      <% else %>
        <div class="flex h-[28rem] items-center justify-center bg-[radial-gradient(circle_at_top,_rgba(167,243,208,0.18),_transparent_35%),linear-gradient(180deg,_rgba(24,24,27,1)_0%,_rgba(17,24,39,1)_100%)] px-6 text-center text-stone-400">
          No image yet for this plant.
        </div>
      <% end %>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <div class="rounded-[1.5rem] border border-white/10 bg-black/10 p-5">
        <p class="text-sm text-stone-400">Location</p>
        <p class="mt-2 text-white"><%= @plant.location_name.presence || "Not set yet" %></p>
      </div>
      <div class="rounded-[1.5rem] border border-white/10 bg-black/10 p-5">
        <p class="text-sm text-stone-400">Added at home</p>
        <p class="mt-2 text-white"><%= @plant.acquired_at&.to_fs(:long) || "Not set yet" %></p>
      </div>
    </div>

    <% if @plant.description.present? %>
      <div class="mt-6 rounded-[1.5rem] border border-white/10 bg-black/10 p-5">
        <p class="text-sm text-stone-400">Story</p>
        <p class="mt-3 leading-7 text-stone-200"><%= @plant.description %></p>
      </div>
    <% end %>
  </div>

  <aside class="space-y-6">
    <section class="rounded-[2rem] border border-white/10 bg-stone-900/80 p-6">
      <div class="flex items-center justify-between">
        <h2 class="font-serif text-2xl text-white">Timeline</h2>
        <span class="text-sm text-stone-400"><%= @plant_events.size %> events</span>
      </div>

      <div class="mt-5 space-y-4">
        <% @plant_events.each do |event| %>
          <div class="rounded-[1.25rem] border border-white/10 bg-black/10 p-4">
            <div class="flex items-center justify-between gap-4">
              <p class="text-white"><%= event.title %></p>
              <span class="text-sm text-emerald-200"><%= event.xp_delta.positive? ? "+#{event.xp_delta}" : event.xp_delta %> XP</span>
            </div>
            <p class="mt-1 text-sm text-stone-400"><%= event.event_type.humanize %> • <%= event.occurred_at.to_fs(:long) %></p>
            <% if event.notes.present? %>
              <p class="mt-3 text-sm leading-6 text-stone-300"><%= event.notes %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-[2rem] border border-white/10 bg-stone-900/80 p-6">
      <div class="flex items-center justify-between">
        <h2 class="font-serif text-2xl text-white">Photos</h2>
        <span class="text-sm text-stone-400"><%= @plant_photos.size %> uploads</span>
      </div>

      <div class="mt-5 space-y-4">
        <% @plant_photos.each do |photo| %>
          <div class="overflow-hidden rounded-[1.25rem] border border-white/10 bg-black/10">
            <% if photo.image.attached? %>
              <%= image_tag photo.image, class: "h-44 w-full object-cover" %>
            <% end %>
            <div class="p-4">
              <p class="text-sm text-stone-400"><%= photo.taken_at.to_fs(:long) %></p>
              <% if photo.notes.present? %>
                <p class="mt-2 text-sm leading-6 text-stone-300"><%= photo.notes %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </aside>
</section>
