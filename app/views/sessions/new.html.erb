<% content_for :title, "Sign in | plante.io" %>

<section class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[1.1fr_0.9fr]">
  <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8">
    <p class="text-sm uppercase tracking-[0.2em] text-emerald-200/80">Sign in</p>
    <h1 class="mt-3 font-serif text-4xl text-white">Welcome back to your greenhouse.</h1>
    <p class="mt-4 max-w-lg text-stone-300">
      Track growth, add fresh photos, and keep building a living collection around the plants you already love.
    </p>
  </div>

  <div class="rounded-[2rem] border border-white/10 bg-stone-900/80 p-8">
    <%= form_with url: session_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-stone-300" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none transition placeholder:text-stone-500 focus:border-emerald-300/40", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "mb-2 block text-sm text-stone-300" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none transition placeholder:text-stone-500 focus:border-emerald-300/40", placeholder: "Your password" %>
      </div>

      <%= form.submit "Sign in", class: "w-full rounded-full bg-emerald-300 px-5 py-3 font-medium text-stone-950 transition hover:bg-emerald-200" %>
    <% end %>

    <div class="mt-5 flex items-center justify-between text-sm">
      <%= link_to "Forgot password?", new_password_path, class: "text-stone-400 transition hover:text-white" %>
      <%= link_to "Create account", sign_up_path, class: "text-emerald-200 transition hover:text-emerald-100" %>
    </div>
  </div>
</section>
