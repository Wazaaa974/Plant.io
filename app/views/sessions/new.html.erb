<% content_for :title, "Sign in | plante.io" %>

<section class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
  <div class="relative overflow-hidden rounded-[2.3rem] border border-white/8 bg-white/5 p-8 lg:p-10">
    <div class="absolute right-[-10%] top-[-10%] h-56 w-56 rounded-full pio-aura-mint blur-2xl"></div>
    <div class="absolute bottom-[-16%] left-[-10%] h-48 w-48 rounded-full pio-aura-violet blur-2xl"></div>

    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[var(--pio-leaf)]/80">
        <span class="inline-block h-2 w-2 rounded-full bg-[var(--pio-mint)] shadow-[0_0_12px_rgba(91,255,152,0.8)]"></span>
        Journal de croissance vivant
      </div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--pio-leaf)]/75">Connexion</p>
      <h1 class="mt-3 max-w-xl font-serif text-[2.8rem] leading-[0.98] tracking-[-0.08em] text-[var(--pio-cream)]">
        Reviens dans ta <span class="text-[var(--pio-leaf)]">jungle vivante</span>.
      </h1>
      <p class="mt-4 max-w-md text-sm leading-7 text-white/58">
        plante.io transforme tes plantes en compagnons que tu peux photographier, faire progresser et retrouver dans une collection vivante.
      </p>

      <div class="mt-6 grid gap-2 text-sm text-white/62">
        <div class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-[var(--pio-mint)]/12 text-[var(--pio-mint)]"><%= pio_icon(:camera, size: 12, stroke_width: 2.3) %></span>
          <p>Ajoute une photo, un nom, puis suis l'evolution de chaque plante dans le temps.</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-[var(--pio-sun)]/12 text-[var(--pio-sun)]"><%= pio_icon(:sparkle, size: 12, stroke_width: 2.3) %></span>
          <p>XP, niveaux et stades rendent la croissance visible sans perdre le cote reel.</p>
        </div>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        <div class="pio-glass rounded-[1.4rem] p-4">
          <div class="mb-3 grid h-9 w-9 place-items-center rounded-[0.9rem] bg-[var(--pio-mint)]/16 text-[var(--pio-mint)]">
            <%= pio_icon(:sparkle, size: 18, stroke_width: 2.1) %>
          </div>
          <p class="font-display text-sm font-semibold text-[var(--pio-cream)]">Croissance visible</p>
          <p class="mt-1 text-[0.78rem] leading-5 text-white/45">L'historique photo et l'XP racontent une progression lente mais concrete.</p>
        </div>

        <div class="pio-glass rounded-[1.4rem] p-4">
          <div class="mb-3 grid h-9 w-9 place-items-center rounded-[0.9rem] bg-[var(--pio-sun)]/16 text-[var(--pio-sun)]">
            <%= pio_icon(:camera, size: 18, stroke_width: 2.1) %>
          </div>
          <p class="font-display text-sm font-semibold text-[var(--pio-cream)]">Compagnons vegetaux</p>
          <p class="mt-1 text-[0.78rem] leading-5 text-white/45">Chaque plante devient une carte vivante avec stade, aura et souvenirs.</p>
        </div>
      </div>

      <div class="mt-6 rounded-[1.3rem] border border-white/8 bg-[rgba(6,18,14,0.34)] p-4">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-white/42">En revenant ici, tu retrouves</p>
        <div class="mt-3 grid gap-2 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/6 bg-white/4 px-3 py-3">
            <p class="text-[0.72rem] text-white/40">Collection</p>
            <p class="mt-1 text-sm font-semibold text-[var(--pio-cream)]">Toutes tes plantes</p>
          </div>
          <div class="rounded-2xl border border-white/6 bg-white/4 px-3 py-3">
            <p class="text-[0.72rem] text-white/40">Progression</p>
            <p class="mt-1 text-sm font-semibold text-[var(--pio-cream)]">Niveau, XP, stades</p>
          </div>
          <div class="rounded-2xl border border-white/6 bg-white/4 px-3 py-3">
            <p class="text-[0.72rem] text-white/40">Histoire</p>
            <p class="mt-1 text-sm font-semibold text-[var(--pio-cream)]">Photos et evenements</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pio-glass rounded-[2.1rem] p-7 sm:p-8">
    <div class="mb-6">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white/42">Sign in</p>
      <h2 class="mt-2 font-display text-[1.85rem] font-semibold tracking-[-0.05em] text-[var(--pio-cream)]">Bienvenue de retour.</h2>
      <p class="mt-2 text-sm leading-6 text-white/50">Reconnecte-toi pour voir ce qui a pousse, ajouter une photo ou continuer ta collection.</p>
    </div>

    <%= form_with url: session_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "mb-2 block text-sm text-white/62" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "mb-2 block text-sm text-white/62" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "pio-field w-full rounded-[1.15rem] px-4 py-3", placeholder: "Your password" %>
      </div>

      <%= form.submit "Entrer dans ma jungle", class: "inline-flex w-full items-center justify-center rounded-full bg-[linear-gradient(160deg,_var(--pio-mint),_var(--pio-leaf))] px-5 py-3 text-sm font-semibold text-[var(--pio-forest)] shadow-[0_10px_24px_rgba(91,255,152,0.28)]" %>
    <% end %>

    <div class="mt-5 flex items-center justify-between gap-3 text-sm">
      <%= link_to "Forgot password?", new_password_path, class: "text-white/46 transition hover:text-white" %>
      <%= link_to "Create account", sign_up_path, class: "font-semibold text-[var(--pio-leaf)] transition hover:text-[var(--pio-mint)]" %>
    </div>
  </div>
</section>
